<?xml version="1.0" encoding="utf-8"?>
<rss version="2.0"
     xmlns:sparkle="http://www.andymatuschak.org/xml-namespaces/sparkle"
     xmlns:dc="http://purl.org/dc/elements/1.1/">
    <channel>
        <title>RedactDesk</title>
        <link>https://raw.githubusercontent.com/RedactDesk/redactdesk-mac/main/appcast.xml</link>
        <description>Signed update feed for RedactDesk. New entries are generated by Scripts/sparkle-release.sh.</description>
        <language>en</language>

        <!--
          To publish a new release:
            1. Build, sign, and notarize a Release DMG.
            2. Cut a GitHub release on RedactDesk/redactdesk-mac tagged vX.Y.Z
               and upload the DMG as a release asset.
            3. Run Scripts/sparkle-release.sh <artifact> <shortVersion> <buildNumber>
            4. Paste the emitted <item> block above this comment.
            5. Commit the updated appcast.xml to main - Sparkle reads it
               straight from raw.githubusercontent.com.
        -->
    </channel>
</rss>
